/* ===== HARD LOGIN GATE ===== */

/* Fullscreen overlay that appears BEFORE anything */
#login-gate {
  position: fixed;
  inset: 0;
  z-index: 3000;
  display: flex;
  align-items: center;
  justify-content: center;
  background:
    radial-gradient(1200px 600px at 50% 40%, rgba(40,40,40,0.5), transparent 60%),
    rgba(0,0,0,0.85);
  backdrop-filter: blur(6px);
}

/* Make sure the login card itself is crisp and on top */
#login-gate .login-form {
  position: relative !important;
  z-index: 3100 !important;
  background: #000;
  border: 1px solid #222;
  border-radius: 14px;
  padding: 22px;
  box-shadow: 0 0 40px rgba(0,0,0,0.6);
}

/* While logged OUT:
   - hide/disable everything except the gate
   - stop scroll so the page doesn't move behind the gate */
body:not(.is-logged-in) {
  overflow: hidden;
}

body:not(.is-logged-in) .container > :not(#login-gate):not(.reset-modal) {
  pointer-events: none !important;
  user-select: none !important;
  opacity: 0 !important;
}

/* When logged IN: gate disappears automatically (React unmounts it) */
body.is-logged-in #login-gate {
  display: none !important;
}

