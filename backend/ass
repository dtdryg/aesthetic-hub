/* --- AESTHETIC PERMA-CURSOR (no blink, smooth RGB) --- */

/* Override the earlier blink with a non-disappearing RGB gradient */
.cmd-cursor {
  /* kill the old blink and replace it with our flow animation */
  animation: caretFlow 6s linear infinite !important;

  /* always visible */
  opacity: 1 !important;

  /* neon rainbow bar */
  background-image: linear-gradient(90deg,
    #ff6ec7, #ffd166, #06d6a0, #118ab2, #9b5de5, #ff6ec7
  );
  background-size: 300% 100%;

  /* subtle glow + nicer shape */
  border-radius: 2px;
  box-shadow:
    0 0 8px rgba(255,255,255,0.18),
    0 0 18px rgba(0,255,160,0.12);

  /* size — keep or tweak */
  width: 10px !important;
  height: 22px !important;
  margin-left: 5px;
}

/* === PERMA-CURSOR: kill blink + add smooth RGB flow (global overrides) === */

/* Hit every likely caret class (RainbowCaret, custom caret, etc.) */
.cmd-cursor,
.rainbow-caret,
.rainbow-caret::after,
.cmd-cursor::after,
.cmd-cursor::before {
  /* replace any prior blink animation */
  animation: caretFlowX 6s linear infinite !important;

  /* make sure it never hides */
  opacity: 1 !important;
  visibility: visible !important;
  display: inline-block !important;

  /* neon gradient bar */
  background-image: linear-gradient(90deg,
    #ff6ec7, #ffd166, #06d6a0, #118ab2, #9b5de5, #ff6ec7
  );
  background-size: 300% 100%;
  border-radius: 2px;
  box-shadow:
    0 0 8px rgba(255,255,255,0.18),
    0 0 18px rgba(0,255,160,0.12);
}

/* size — keep or tweak */
.cmd-cursor,
.rainbow-caret {
  width: 10px !important;
  height: 22px !important;
  margin-left: 5px;
}

/* If some other rule still toggles blink via keyframes named 'blink' */
.cmd-cursor,
.rainbow-caret {
  animation-name: caretFlowX !important;
}

/* Show the left-top utility stack ONLY on Users tab */
