/* Base tab button */
.tab {
  position: relative;
  background: transparent;
  color: #fff;
  border: 0;
  padding: 10px 14px;
  font-weight: 700;
  cursor: pointer;
  border-radius: 8px;
}

/* Optional hover for normal tabs */
.tab:not(.aesth):hover {
  background: #111;
  border: 1px solid #222;
}

/* ── Rainbow magic just for $AESTH ────────────────────────── */
@keyframes hueSlide {
  0%   { background-position: 0% 50%; }
  100% { background-position: 400% 50%; }
}

/* gradient text */
.tab.aesth {
  /* animated rainbow gradient clipped to text */
  background-image: linear-gradient(90deg,
    #ff6ec7, #ffd166, #06d6a0, #118ab2, #9b5de5, #ff6ec7
  );
  background-size: 400% 100%;
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  animation: hueSlide 6s linear infinite;
}

/* underline line (animated) */
.tab.aesth::after {
  content: "";
  position: absolute;
  left: 10px;
  right: 10px;
  bottom: 4px;
  height: 2px;
  background-image: linear-gradient(90deg,
    #ff6ec7, #ffd166, #06d6a0, #118ab2, #9b5de5, #ff6ec7
  );
  background-size: 400% 100%;
  animation: hueSlide 6s linear infinite;
  filter: drop-shadow(0 0 4px rgba(255,255,255,.35));
  border-radius: 999px;
}

/* make it pop when that tab is active */
.tab.aesth.active::after {
  height: 3px;
  bottom: 3px;
  filter: drop-shadow(0 0 6px rgba(255,255,255,.6));
}

/* (Optional) remove default focus ring + add nicer focus for keyboard users */
.tab:focus {
  outline: none;
}
.tab.aesth:focus-visible::after {
  box-shadow: 0 0 0 4px rgba(255,255,255,.12);
}

