  border-radius: 50%; /* circular glow */
  animation: fadeCaret 1.6s ease-in-out infinite;
}


/* Keep inputs aligned with the fake caret */
.input-with-caret {
  display: inline-flex;
  align-items: center;
  position: relative;
}
.input-with-caret input {
  flex: 1;
  background: transparent;
  border: 1px solid #333;
  padding: 6px 10px;
  color: #fff;
}



/* 🔮 Neon purple glow when typing in inputs/textarea */
input:focus, textarea:focus {
  outline: none;
  border: 1px solid #d59aff;
  box-shadow: 0 0 12px rgba(213, 154, 255, 0.7), 
              0 0 24px rgba(213, 154, 255, 0.4);
  transition: all 0.25s ease-in-out;
}
/* Hide default caret everywhere */
input, textarea, [contenteditable="true"] {
  caret-color: transparent !important;
}

/* Add spinner caret inside inputs */
.input-with-spinner {
  position: relative;
  display: inline-flex;
  align-items: center;
}

.input-with-spinner input,
.input-with-spinner textarea {
  padding-right: 16px; /* room for spinner */
}

/* Spinner caret positioned at end */
.input-with-spinner .cmd-spinner {
  position: absolute;
  right: 6px;
  top: 50%;
  transform: translateY(-50%);
}
/* Global focus glow (for buttons, tabs, links) */
button:focus, .tab:focus, a:focus {
  outline: none;
  border: 1px solid #d59aff;
  box-shadow: 0 0 10px rgba(213, 154, 255, 0.7);
  border-radius: 8px;
}
.login-tabs {
  display: flex;
  justify-content: center;
  margin-bottom: 16px;
  gap: 10px;
}

.login-tabs button {
  background: #111;
  color: #fff;
  border: 1px solid #333;
  padding: 8px 14px;
  border-radius: 8px;
  cursor: pointer;
  transition: 0.2s;
}

.login-tabs button.active {
  border-color: #d59aff;
  box-shadow: 0 0 10px rgba(213,154,255,0.6);
}
/* Wrap input in a container */
.input-wrap {
  position: relative;
  display: inline-block;
}

.input-wrap input {
  font-family: monospace; /* makes it look like CMD */
  padding-right: 14px; /* space for fake caret */
}

/* Fake caret */


input, textarea {
  caret-color: transparent; /* hide native caret */
}
.input-wrap {
  position: relative;
  display: inline-block;
}
/* 🔥 Force global spinning / caret */
input, textarea {
  caret-color: transparent !important; /* hide native */
  position: relative; /* anchor for pseudo element */
}

input:focus::after,
textarea:focus::after {
  content: "/";
  position: absolute;
  left: auto;
  right: 6px; /* puts spinner at end of text */
  top: 50%;
  transform: translateY(-50%);
  animation: cmd-spin 1s steps(4) infinite;
  color: #fff;
  pointer-events: none;
}
